  "description": "Shroom - Pressure Sensor Data Acquisition & Visualization System",
  "main": "index.js",
  "win": {
    "icon": "./logo.ico"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron-forge start",
    "build-client": "npm --prefix client run build",
    "build-python-runtime": "node scripts/build-python-runtime.js",
    "prepare-pack-resources": "npm run build-python-runtime && node scripts/sync-pack-resources.js",
    "prepare-build-assets": "npm run build-client && npm run prepare-pack-resources",
    "package": "npm run prepare-build-assets && electron-forge package",
    "make": "npm run prepare-build-assets && electron-forge make",
    "make-mac": "npm run prepare-build-assets && electron-forge make --platform darwin",
    "make-start": "electron-forge start --platform darwin",
    "build": "npm run prepare-build-assets && electron-builder -w && node scripts/inject-release-notes.js",
    "build-mac": "npm run prepare-build-assets && electron-builder -m",
    "build-mac-release": "node scripts/build-mac-release.js",
    "build-mac-share": "node scripts/build-mac-share.js",
    "build-all": "npm run prepare-build-assets && electron-builder -mwl"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./logo",
        "asar": true,
        "extraResource": [
          "./build",
          "./pack-resources/db",
          "./pack-resources/python"
        ],
        "ignore": [
          "^/venv($|/)",
          "^/python($|/)",
          "^/__pycache__($|/)",
          "\\.pyc$",
          "^/build($|/)",
          "^/data($|/)",
          "^/db($|/)",
          "^/pack-resources($|/)",
          "^/client($|/)",
          "^/docs($|/)",
          "^/config\\.txt$"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ],
          "config": {
            "options": {
              "icon": "./logo.icns"
            }
          }
        }
      ]
    }
  },
  "author": "jq",
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.58.2",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
