## 7. 串口数据采集集成示例

在实际应用中，数据通常从串口采集。以下示例展示了如何从串口读取帧数据并送入算法包处理：

```python
import serial
import numpy as np
import pet_care_wrapper as pcw

# 串口协议常量
BAUD_RATE = 1000000
FRAME_HEADER = bytes([0xAA, 0x55, 0x03, 0x99])  # 4 字节帧头
FRAME_DATA_LEN = 1024                             # 32x32 = 1024 字节
FRAME_TOTAL_LEN = len(FRAME_HEADER) + FRAME_DATA_LEN  # 1028 字节

def run_serial_monitoring(port="COM5", species=1.0, threshold=1.0):
    """从串口采集数据并实时处理"""

    # 初始化算法包
    pcw.initialize()

    # 打开串口
    ser = serial.Serial(port, BAUD_RATE, timeout=1)
    buf = bytearray()
    frame_count = 0
    skip_counter = 0  # 用于 100Hz->50Hz 降采样

    try:
        while True:
            # 读取串口数据
            chunk = ser.read(4096)
            if not chunk:
                continue
            buf.extend(chunk)

            # 搜索帧头并提取完整帧
            while len(buf) >= FRAME_TOTAL_LEN:
                idx = buf.find(FRAME_HEADER)
                if idx < 0:
                    buf = buf[-3:]  # 保留末尾可能的部分帧头
                    break
                if idx > 0:
                    del buf[:idx]   # 丢弃帧头前的无效数据
                if len(buf) < FRAME_TOTAL_LEN:
                    break

                # 提取帧数据 (跳过 4 字节帧头)
                frame_bytes = buf[len(FRAME_HEADER):FRAME_TOTAL_LEN]
                del buf[:FRAME_TOTAL_LEN]

                # 间隔一帧传一次 (100Hz -> 50Hz)
                skip_counter += 1
                if skip_counter < 2:
                    continue
                skip_counter = 0

                # 转换为 float32 数组并送入算法
                frame_data = np.frombuffer(frame_bytes, dtype=np.uint8).astype(np.float32)
                inputs = {
                    'frame_data': frame_data,
                    'threshold_factor': threshold,
                    'species': species
                }
                outputs = pcw.step(inputs)

                frame_count += 1
                if frame_count % 50 == 0:
                    print(f"帧 {frame_count}: 呼吸率={outputs['breath_rate']:.1f} bpm")

    except KeyboardInterrupt:
        print("停止监测")
    finally:
        pcw.terminate()
        ser.close()

if __name__ == "__main__":
    run_serial_monitoring(port="COM5", species=1.0)
```

