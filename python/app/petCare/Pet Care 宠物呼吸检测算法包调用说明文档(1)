## 6. 标准调用示例代码

以下是一个完整的 Python 调用示例，展示了如何初始化、循环处理数据以及安全退出：

```python
import numpy as np
import time
import pet_care_wrapper as pcw

def main():
    # ========== 1. 查看模块信息 ==========
    info = pcw.get_info()
    print("算法包信息:", info)

    # ========== 2. 初始化算法包 (必须在 step 之前调用) ==========
    print("初始化算法包...")
    pcw.initialize()

    try:
        # ========== 3. 数据采集与处理循环 ==========
        for frame_idx in range(1000):
            # --- 获取一帧 32x32 的传感器数据 ---
            # 实际使用时从串口/传感器读取，这里用随机数据模拟
            raw_matrix_2d = np.random.randint(0, 255, size=(32, 32), dtype=np.uint8)

            # 展平为 1024 长度的一维 float32 数组
            frame_data_flat = raw_matrix_2d.flatten().astype(np.float32)

            # --- 构建输入字典 ---
            inputs = {
                'frame_data': frame_data_flat,       # 必填: 1024 长度 float32 数组
                'threshold_factor': 1.0,             # 可选: 阈值因子, 默认 1.0
                'species': 1.0                       # 可选: 物种编号, 1.0=猫
            }

            # --- 调用算法步进处理 ---
            outputs = pcw.step(inputs)

            # --- 解析输出结果 ---
            breath_rate       = outputs['breath_rate']        # 呼吸率 (BPM)
            posture_state     = outputs['posture_state']      # 姿态状态
            is_motion         = outputs['is_motion']          # 体动标志
            snr_db            = outputs['snr_db']             # 信噪比 (dB)
            quality           = outputs['quality']            # 信号质量 (0-10)
            bed_exit_flag     = outputs['bed_exit_flag']      # 离床标志
            pressure_coeff    = outputs['pressure_coefficient']  # 压力系数
            matrix_origin     = outputs['matrix_origin']      # 原始矩阵 (1024,)

            # 还原为 32x32 二维矩阵 (用于热力图显示)
            matrix_2d = matrix_origin.reshape(32, 32)

            # 每 50 帧打印一次关键信息
            if frame_idx % 50 == 0:
                print(f"帧 {frame_idx:4d}: "
                      f"呼吸率={breath_rate:5.1f} bpm, "
                      f"姿态={posture_state:.0f}, "
                      f"体动={is_motion:.0f}, "
                      f"SNR={snr_db:5.1f} dB, "
                      f"质量={quality:.1f}, "
                      f"离床={bed_exit_flag:.0f}, "
                      f"压力系数={pressure_coeff:.2f}")

            # 模拟 50Hz 的采样间隔 (20ms)
            time.sleep(0.02)

    except KeyboardInterrupt:
        print("\n监测被用户中断")
    except Exception as e:
        print(f"发生错误: {e}")
    finally:
        # ========== 4. 终止算法包，释放资源 (必须) ==========
        print("释放算法资源...")
        pcw.terminate()
        print("完成。")

if __name__ == "__main__":
    main()
```

